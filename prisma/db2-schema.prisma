// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator db2_client {
  provider = "prisma-client"
  output   = "../generated/prisma-db2"
}

datasource db2_db {
  provider = "sqlite"
}

model db2_User {
  id    Int     @id @default(autoincrement())
  // Error parsing attribute "@unique": The given constraint name `User_email_key` has to be unique in the following namespace: global for indexes and unique constraints. Please provide a different name using the `map` argument.
  email String  @unique
  name  String?
  // The model with database name "User" could not be defined because another model or view with this name exists: "db1_User"
  @@map("User")
}