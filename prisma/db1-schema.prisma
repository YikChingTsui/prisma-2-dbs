// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator db1_client {
  provider = "prisma-client"
  output   = "../generated/prisma-db1"
}

datasource db1_db {
  provider = "sqlite"
}

model db1_User {
  id    Int     @id @default(autoincrement())
  // Error parsing attribute "@unique": The given constraint name `User_email_key` has to be unique in the following namespace: global for indexes and unique constraints. Please provide a different name using the `map` argument.
  email String  @unique
  name  String?
  @@map("User")
}